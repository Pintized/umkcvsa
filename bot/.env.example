# Copy this file to .env (in this bot/ folder) and fill in real values.
# .env is gitignored — when migrating to a new PC, this file is the only
# thing you copy over manually; everything else comes from git clone.
# NEVER put real values in this .env.example file — it is committed to GitHub.

# From https://discord.com/developers/applications -> your app
DISCORD_TOKEN=            # Bot tab -> Reset Token
DISCORD_APP_ID=           # General Information -> Application ID
DISCORD_GUILD_ID=         # Right-click your server icon -> Copy Server ID (needs Developer Mode)

# Channel where the bot posts welcome messages (right-click channel -> Copy Channel ID).
# Leave blank to disable welcomes.
WELCOME_CHANNEL_ID=

# Channel where moderation offense reports are posted. Leave blank to disable.
MOD_LOG_CHANNEL_ID=

# Supabase project (Dashboard -> Settings -> API). Service role key is SECRET.
# Used for the moderation warning counter.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
